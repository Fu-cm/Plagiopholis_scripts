set(seed:73412305)
set(outgroup:"Thermophiszhaoermii")
read(nucleotide:"13p2s.fas")
build(distance, rdwag, replicates:50)
swap(alternate, keep:10)
fuse(tbr:10, keep:1)
report("2Plagiopholis_cr1.csv", crossrefs, overwrite)
report("2Plagiopholis_data1.csv", data, overwrite)
report("2Plagiopholis_run1.tre", newick, graphs, overwrite)
report("2Plagiopholis_ia1.fas", ia, overwrite)
report("2Plagiopholis_run1.dot",support,  graphs, dotpdf, overwrite)
